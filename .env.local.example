# Supabase — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare R2 (compatible S3) — ya generadas, guardar como variables de entorno en Vercel
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=

# Opcional: dominio público si el bucket tiene acceso público/CDN configurado
R2_PUBLIC_URL=

# Correos autorizados a entrar a /admin, separados por coma
ADMIN_EMAILS=
